OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_CLIENT_ID=replace-me
OAUTH2_PROXY_CLIENT_SECRET=replace-me
OAUTH2_PROXY_OIDC_ISSUER_URL=http://authentik-server:9000/application/o/bap-search/
OAUTH2_PROXY_SCOPE=openid profile email
OAUTH2_PROXY_CODE_CHALLENGE_METHOD=S256
OAUTH2_PROXY_USER_ID_CLAIM=sub
OAUTH2_PROXY_EMAIL_CLAIM=email
OAUTH2_PROXY_INSECURE_OIDC_ALLOW_UNVERIFIED_EMAIL=true
OAUTH2_PROXY_COOKIE_SECRET=0123456789abcdefghijklmnopqrstuv
OAUTH2_PROXY_REDIRECT_URL=http://localhost:8080/oauth2/callback
AUTH_PROXY_PUBLIC_PORT=8080
BAP_PUBLIC_PORT=8080
BAP_ALLOW_ANONYMOUS=true

# Host paths for bap-search data (bind mounts).
# Defaults are relative to the docker/ directory.
# Override with absolute paths to store data anywhere on the host:
# BAP_MODELS_PATH=/data/bapsearch/models
# BAP_LOGS_PATH=/data/bapsearch/logs
# BAP_DATABASE_PATH=/data/bapsearch/database

# Host paths for Authentik data (bind mounts).
# Directories are created automatically by Docker if they don't exist.
# AUTHENTIK_POSTGRESQL_DATA_PATH=./data/authentik-postgresql
# AUTHENTIK_REDIS_DATA_PATH=./data/authentik-redis
# AUTHENTIK_MEDIA_PATH=./data/authentik-media
# AUTHENTIK_TEMPLATES_PATH=./data/authentik-templates
AUTHENTIK_VERSION=2025.8.3
AUTHENTIK_SECRET_KEY=replace-with-a-long-random-string
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__PASSWORD=replace-with-a-strong-password
AUTHENTIK_BOOTSTRAP_EMAIL=akadmin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me
AUTHENTIK_HTTP_PORT=9000
AUTHENTIK_HTTPS_PORT=9443
LLAMA_ANSWER_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_ANSWER_THREADS=4
LLAMA_ANSWER_CTX_SIZE=8192
LLAMA_ANSWER_N_GPU_LAYERS=0
LLAMA_ANSWER_MAIN_GPU=0
LLAMA_ANSWER_GPUS=all
LLAMA_ANSWER_FLASH_ATTN=false
LLAMA_ANSWER_EXTRA_ARGS=
LLAMA_REWRITE_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_REWRITE_THREADS=4
LLAMA_REWRITE_CTX_SIZE=2048
LLAMA_REWRITE_N_GPU_LAYERS=0
LLAMA_REWRITE_MAIN_GPU=0
LLAMA_REWRITE_GPUS=all
LLAMA_REWRITE_FLASH_ATTN=false
LLAMA_REWRITE_EXTRA_ARGS=
LLAMA_EMBEDDINGS_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_EMBEDDINGS_THREADS=4
LLAMA_EMBEDDINGS_CTX_SIZE=2048
LLAMA_EMBEDDINGS_N_GPU_LAYERS=0
LLAMA_EMBEDDINGS_MAIN_GPU=0
LLAMA_EMBEDDINGS_GPUS=all
LLAMA_EMBEDDINGS_FLASH_ATTN=false
LLAMA_EMBEDDINGS_EXTRA_ARGS=--embeddings --pooling mean --batch-size 2048 --ubatch-size 512
LLAMA_AUTO_RELOAD_MODEL=true
BAP_MAX_EMBEDDING_CHARS=1800
BAP_CHAT_CONTEXT_CHARS=4200
BAP_MAX_CHAT_MESSAGES=8
BAP_LLM_CONTEXT_TOKENS=8192

# Put one filename per role in the shared models directory.
# The answer model is still controlled by models/current-model.txt from the UI.
# The rewrite and embeddings services read these files if they exist:
# - models/current-rewrite-model.txt
# - models/current-embedding-model.txt

# To enable the auth proxy later with a generic OIDC provider:
# docker compose --profile auth -f docker/docker-compose.yml up --build

# To run the included Authentik stack and protect bap-search with oauth2-proxy:
# 1. Set BAP_ALLOW_ANONYMOUS=false
# 2. Set BAP_PUBLIC_PORT=8081 so auth-proxy can keep port 8080
# 3. docker compose --profile auth --profile authentik -f docker/docker-compose.yml up --build

# To enable NVIDIA GPU support later:
# LLAMA_ANSWER_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
# LLAMA_REWRITE_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
# LLAMA_EMBEDDINGS_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
# LLAMA_ANSWER_N_GPU_LAYERS=auto
# LLAMA_REWRITE_N_GPU_LAYERS=auto
# LLAMA_EMBEDDINGS_N_GPU_LAYERS=auto
# If you have multiple GPUs and want to pin each service to a device, set:
# LLAMA_ANSWER_GPUS=device=0
# LLAMA_REWRITE_GPUS=device=1
# LLAMA_EMBEDDINGS_GPUS=device=1
# LLAMA_ANSWER_FLASH_ATTN=true
# LLAMA_REWRITE_FLASH_ATTN=true
# LLAMA_EMBEDDINGS_FLASH_ATTN=true
# docker compose -f docker/docker-compose.yml -f docker/docker-compose.gpu.yml up --build
