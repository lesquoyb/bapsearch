OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_CLIENT_ID=replace-with-authentik-client-id
OAUTH2_PROXY_CLIENT_SECRET=replace-with-authentik-client-secret
OAUTH2_PROXY_OIDC_ISSUER_URL=http://authentik-server:9000/application/o/bap-search/
OAUTH2_PROXY_SCOPE=openid profile email
OAUTH2_PROXY_CODE_CHALLENGE_METHOD=S256
OAUTH2_PROXY_USER_ID_CLAIM=sub
OAUTH2_PROXY_EMAIL_CLAIM=email
OAUTH2_PROXY_INSECURE_OIDC_ALLOW_UNVERIFIED_EMAIL=true
OAUTH2_PROXY_COOKIE_SECRET=0123456789abcdefghijklmnopqrstuv
OAUTH2_PROXY_REDIRECT_URL=http://localhost:8080/oauth2/callback
AUTH_PROXY_PUBLIC_PORT=8080

# Keep the backend reachable directly for debugging while auth-proxy owns 8080.
BAP_PUBLIC_PORT=8081
BAP_ALLOW_ANONYMOUS=false

AUTHENTIK_VERSION=2025.8.3
AUTHENTIK_SECRET_KEY=replace-with-a-long-random-string
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__PASSWORD=replace-with-a-strong-password
AUTHENTIK_BOOTSTRAP_EMAIL=akadmin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me
AUTHENTIK_HTTP_PORT=9000
AUTHENTIK_HTTPS_PORT=9443

LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_THREADS=4
LLAMA_CTX_SIZE=8192
LLAMA_N_GPU_LAYERS=0
LLAMA_MAIN_GPU=0
LLAMA_FLASH_ATTN=false
LLAMA_EXTRA_ARGS=
LLAMA_AUTO_RELOAD_MODEL=true
BAP_CHAT_CONTEXT_CHARS=4200
BAP_MAX_CHAT_MESSAGES=8
BAP_LLM_CONTEXT_TOKENS=8192