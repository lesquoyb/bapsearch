OAUTH2_PROXY_PROVIDER=github
OAUTH2_PROXY_CLIENT_ID=replace-me
OAUTH2_PROXY_CLIENT_SECRET=replace-me
OAUTH2_PROXY_COOKIE_SECRET=0123456789abcdefghijklmnopqrstuv
OAUTH2_PROXY_REDIRECT_URL=http://localhost:8080/oauth2/callback
BAP_ALLOW_ANONYMOUS=true
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_THREADS=4
LLAMA_CTX_SIZE=4096
LLAMA_N_GPU_LAYERS=0
LLAMA_MAIN_GPU=0
LLAMA_FLASH_ATTN=false
LLAMA_EXTRA_ARGS=
LLAMA_AUTO_RELOAD_MODEL=true
BAP_CHAT_CONTEXT_CHARS=4200
BAP_MAX_CHAT_MESSAGES=8
BAP_LLM_CONTEXT_TOKENS=2048

# To enable the auth proxy later:
# docker compose --profile auth -f docker/docker-compose.yml up --build

# To enable NVIDIA GPU support later:
# LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
# LLAMA_N_GPU_LAYERS=999
# LLAMA_FLASH_ATTN=true
# docker compose -f docker/docker-compose.yml -f docker/docker-compose.gpu.yml up --build
